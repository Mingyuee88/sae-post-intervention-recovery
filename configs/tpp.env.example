# Copy this file, edit paths, then source it before running scripts/reproduce_tpp.sh.
# Example:
#   cp configs/tpp.env.example configs/tpp.env
#   edit configs/tpp.env
#   source configs/tpp.env
#   bash scripts/reproduce_tpp.sh

export SAEBENCH_EXTERNAL_ROOT=/path/to/local/SAEBench
export OUTPUT_DIR=runs/tpp
